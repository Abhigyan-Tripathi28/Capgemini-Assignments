<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
        
   <!-- q1- (setter injection)-->
                              
    <context:annotation-config/>                      
    <bean id="book" class="com.cg.bean.Book" scope=""> 
    	  
    	<property name="bookId" value="101"></property>
    	<property name="title" value="ABC"></property>
    	<property name="author" value="MR.X"></property>
    	       
    	
    </bean>  
     
    
    
    <!-- q2-(setter injection)-->
     
	 
    <bean id="lib" class="com.cg.bean.Librarian" scope=""> 
    	<property name="librarianId" value="1001"></property>
    	<property name="name" value="AMIT"></property>
    	
    </bean>
   
    
    
    
</beans>