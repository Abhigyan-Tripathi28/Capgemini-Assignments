    <!-- q3-->
    <bean id="emp1" class="com.cg.bean.Employee" scope=""> 
    	  
    	<property name="eid" value="101"></property>
    	<property name="ename" value="A"></property>
    	<property name="sal" value="100.0"></property>
    	<property name="bu" value="PES-BU"></property>
    	<property name="age" value="21"></property>         
    	
    </bean> 
    <bean id="emp2" class="com.cg.bean.Employee" scope=""> 
    	  
    	<property name="eid" value="102"></property>
    	<property name="ename" value="B"></property>
    	<property name="sal" value="200.0"></property>
    	<property name="bu" value="PES-BU"></property>
    	<property name="age" value="25"></property>
    	           
    </bean> 
    
    <bean id="sbu" class="com.cg.bean.SBU" scope=""> 
    	<property name="sbuId" value="1001"></property>
    	<property name="sbuName" value="Product Engineering Service"></property>
    	<property name="sbuHead" value="Kiran Rao"></property>
    	
    	<property name="empList">
    	  <list>
    	     <ref bean="emp1"/>
    	      <ref bean="emp2"/>
    	  </list>
    	</property>
    	
    </bean>
    
</beans>